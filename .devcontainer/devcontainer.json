{
  "name": "Portfolio Fullstack",
  "dockerComposeFile": "../deployment/docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",
  
  // Hier passiert die Magie: Wir nehmen das .NET 10 Image und installieren Node.js einfach dazu!
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  
  // Alle Extensions für Vue und C# auf einmal
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ]
    }
  },
  
  "forwardPorts": [5341, 5173, 8080, 5433],
  "remoteUser": "vscode"
}